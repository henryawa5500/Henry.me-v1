# Frontend
# Leave empty on Vercel so the app uses /api automatically.
VITE_API_URL=

# Backend auth
JWT_SECRET=replace-with-a-long-random-secret

# Production database
# Use a free Neon Postgres connection string here.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Email
# Use a free Resend API key here.
RESEND_API_KEY=re_...
FROM_EMAIL=HenryME <onboarding@resend.dev>
ADMIN_EMAIL=you@example.com

# Optional local upload behavior.
# On Vercel, uploads are stored as data URLs in Postgres by default.
UPLOAD_STORAGE=database
